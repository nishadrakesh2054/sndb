# Public site URL (required for canonical URLs, sitemap, and Open Graph)
NEXT_PUBLIC_SITE_URL=https://sndb.org.np

# Supabase (from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SMTP (Gmail app password recommended) — server-side only, never expose to client
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
ADMIN_EMAIL=
